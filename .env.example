# Copy to .env.local and fill in. .env.local is gitignored.
#
# Rule: NEXT_PUBLIC_* ships to the browser. Everything else stays server-side.
# If you are unsure which a key is, it stays server-side.

# not from hiding this key.

# LLM — server-side only. Never NEXT_PUBLIC_.
# In Vercel, mark this "Sensitive" (write-only). Sensitive vars can't target the
# Development environment — that's fine, we use `npm run dev` + .env.local.
OPENAI_API_KEY=

# Optional. Defaults to gpt-5-nano, OpenAI's lowest-cost model with image input.
# Set OPENAI_MODEL only when you deliberately want to override the default.
OPENAI_MODEL=gpt-5-nano


# ElevenLabs — server-side only. Powers BoneBot's spoken voice (/api/tts).
# Without it, BoneBot falls back to the browser's built-in voice. Voice input 
# uses the browser's Web Speech API (no key needed).
ELEVENLABS_API_KEY=
# Optional — defaults to a public ElevenLabs voice ("Rachel").
ELEVENLABS_VOICE_ID=

# Resend — server-side only. Powers "Email this result" (/api/send-result),
# a plain REST call (like /api/tts above), no SDK dependency. Free tier, no
# domain needed: sign up at resend.com, the default API key can send from
# onboarding@resend.dev to any address. Without this key, the email button
# shows "unavailable" instead of a stack trace.
RESEND_API_KEY=
